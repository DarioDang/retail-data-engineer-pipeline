[0m19:21:24.280841 [debug] [Thread-1 (]: On model.retail_pipeline.stg_electronic_products: /* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "retail_pipeline", "target_name": "dev", "node_id": "model.retail_pipeline.stg_electronic_products"} */

  create view "retail_pipeline"."staging_staging"."stg_electronic_products__dbt_tmp"
    
    
  as (
    -- Staging model: clean and normalize raw data from Postgres -- 
-- Source : raw_shopping.electronic_products (loaded by dlt)

WITH source AS (
    SELECT *
    FROM "retail_pipeline"."raw_shopping"."electronic_products"
), 

cleaned AS (
    SELECT 
        -- Identifiers -- 
        _dlt_id AS record_id,

        -- Product details --
        TRIM(product_name)      AS product_name,
        LOWER(TRIM(category))   AS category,
        TRIM(title)             AS title,
        
        -- Pricing
        ROUND(price::numeric, 2)        AS price,
        ROUND(old_price::numeric, 2)    AS old_price,

        -- Discount calculation
        CASE
            WHEN old_price IS NOT NULL AND old_price > 0
            THEN ROUND(((old_price - price) / old_price * 100)::numeric, 2)
            ELSE NULL
        END AS discount_pct,

        -- Seller info
        TRIM(seller) AS seller,

        -- Ratings
        ROUND(rating::numeric, 1)   AS rating,
        reviews::integer            AS reviews,
        position::integer           AS position,

        -- Timestamps
        ingested_at::timestamp with time zone   AS ingested_at,
        DATE(ingested_at)                       AS snapshot_date

    FROM source
    WHERE
        price IS NOT NULL
        AND product_name IS NOT NULL
        AND seller IS NOT NULL
)

SELECT * FROM cleaned
  );
