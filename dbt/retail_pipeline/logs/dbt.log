[0m20:04:44.858010 [debug] [Thread-1 (]: On model.retail_pipeline.dim_store: /* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "retail_pipeline", "target_name": "dev", "node_id": "model.retail_pipeline.dim_store"} */

  
    

  create  table "retail_pipeline"."dev_marts"."dim_store__dbt_tmp"
  
  
    as
  
  (
    -- Dimension: unique sellers/stores
WITH staging AS (
    SELECT DISTINCT seller
    FROM "retail_pipeline"."dev_staging"."stg_electronic_products"
    WHERE seller IS NOT NULL
)

SELECT 
    md5(cast(coalesce(cast(seller as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) AS store_id,
    seller AS store_name
FROM staging
ORDER BY store_name
  );
  
