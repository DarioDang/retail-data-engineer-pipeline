[0m20:28:10.952128 [debug] [Thread-2 (]: On model.retail_pipeline.fact_price_snapshot: /* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "retail_pipeline", "target_name": "dev", "node_id": "model.retail_pipeline.fact_price_snapshot"} */

  
    

  create  table "retail_pipeline"."dev_marts"."fact_price_snapshot__dbt_tmp"
  
  
    as
  
  (
    -- Fact table: daily price snapshot for each product per seller
WITH staging AS (
    SELECT 
        record_id,
        product_name,
        category,
        price,
        old_price,
        discount_pct,
        seller,
        rating
        reviews,
        position,
        ingested_at,
        snapshot_date
    FROM "retail_pipeline"."dev_staging"."stg_electronic_products"
),

product AS (
    SELECT 
        product_id,
        product_name,
        category
    FROM "retail_pipeline"."dev_marts"."dim_product"
),

stores AS (
    SELECT 
        store_id,
        store_name
    FROM "retail_pipeline"."dev_marts"."dim_store"
)

SELECT 
    -- KEYS --
    stg.record_id,
    p.product_id,
    s.store_id,

    -- Rating reliability indicator --
    CASE
        WHEN stg.rating IS NOT NULL AND stg.reviews >= 10 THEN 'verified'
        WHEN stg.rating IS NOT NULL AND stg.reviews < 10  THEN 'limited'
        ELSE 'unrated'
    END AS rating_status,

    -- Snapshot info -- 
    stg.product_name,
    stg.category,
    stg.price,
    stg.position,

    -- Store --
    stg.seller,

    -- Engagement --
    stg.rating,
    stg.reviews

FROM staging AS stg 
LEFT JOIN product AS p
    ON stg.product_name = p.product_name
LEFT JOIN stores AS s
    ON stg.seller = s.store_name
ORDER BY stg.snapshot_date DESC, stg.product_name
  );
  
